/* miniprogram/pages/chat/chat.wxss */

.container {
  display: flex;
  flex-direction: column;
  height: 100vh;
  background: #f0f4f0;
  position: relative;
}

/* ── 左上角汉堡导航 ── */
.nav-bar {
  position: fixed;
  top: 0;
  left: 0;
  z-index: 10;
}
.nav-hamburger {
  width: 80rpx;
  height: 80rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 36rpx;
  color: #fff;
  background: #4CAF50;
  border-radius: 0 0 16rpx 0;
}

/* ── 消息列表 ── */
.msg-list {
  flex: 1;
  padding: 100rpx 20rpx 160rpx;
  overflow: hidden;
}

/* ── 空状态 ── */
.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 80rpx 40rpx 0;
}
.empty-icon {
  width: 120rpx;
  height: 120rpx;
  margin-bottom: 20rpx;
  border-radius: 24rpx;
}
.empty-title {
  font-size: 36rpx;
  font-weight: bold;
  color: #2e7d32;
  margin-bottom: 12rpx;
}
.empty-desc {
  font-size: 26rpx;
  color: #888;
  text-align: center;
  line-height: 1.7;
  white-space: pre-wrap;
  margin-bottom: 40rpx;
}
.quick-list {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
  justify-content: center;
}
.quick-item {
  background: #fff;
  border: 1rpx solid #c8e6c9;
  color: #388e3c;
  border-radius: 32rpx;
  padding: 12rpx 28rpx;
  font-size: 26rpx;
}

/* ── 消息行 ── */
.msg-row {
  display: flex;
  align-items: flex-start;
  margin-bottom: 24rpx;
}
.msg-user  { flex-direction: row-reverse; }
.msg-ai    { flex-direction: row; }

/* ── 头像 ── */
.avatar {
  width: 72rpx;
  height: 72rpx;
  border-radius: 50%;
  flex-shrink: 0;
}
.avatar-ai   { margin-right: 16rpx; background: #e8f5e9; }
.avatar-user { margin-left: 16rpx; background: #e3f2fd; }

/* ── 气泡 ── */
.bubble {
  max-width: 74%;
  border-radius: 16rpx;
  padding: 20rpx 24rpx;
  line-height: 1.7;
  font-size: 28rpx;
  word-break: break-all;
}
.bubble-user {
  background: #4CAF50;
  color: #fff;
  border-top-right-radius: 4rpx;
}
.bubble-ai {
  background: #fff;
  color: #333;
  border-top-left-radius: 4rpx;
  box-shadow: 0 2rpx 8rpx rgba(0,0,0,0.06);
}

/* ── 打字机光标 ── */
.cursor {
  display: inline;
  color: #4CAF50;
  animation: blink 0.8s infinite;
  font-size: 32rpx;
}
@keyframes blink {
  0%, 100% { opacity: 1; }
  50%       { opacity: 0; }
}

/* ── 内联病害图片 ── */
.inline-img {
  display: block;
  width: 100%;
  border-radius: 10rpx;
  margin: 12rpx 0;
}

/* ── 底部占位 ── */
.list-bottom-pad { height: 20rpx; }

/* ── 输入区 ── */
.input-bar {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  display: flex;
  align-items: flex-end;
  padding: 16rpx 20rpx;
  padding-bottom: calc(16rpx + env(safe-area-inset-bottom));
  background: #fff;
  box-shadow: 0 -2rpx 12rpx rgba(0,0,0,0.06);
  gap: 16rpx;
}
.input-box {
  flex: 1;
  background: #f5f5f5;
  border-radius: 20rpx;
  padding: 16rpx 24rpx;
  font-size: 28rpx;
  min-height: 72rpx;
  max-height: 200rpx;
  line-height: 1.5;
}
/* ── 汉堡按钮 ── */
.hamburger-btn {
  width: 72rpx;
  height: 72rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 36rpx;
  color: #555;
  flex-shrink: 0;
}

/* ── 抽屉遮罩 ── */
.drawer-mask {
  position: fixed;
  top: 0; left: 0; right: 0; bottom: 0;
  background: rgba(0,0,0,0.35);
  z-index: 100;
}

/* ── 抽屉面板 ── */
.drawer {
  position: fixed;
  top: 0; left: 0; bottom: 0;
  width: 560rpx;
  background: #fff;
  z-index: 101;
  transform: translateX(-100%);
  transition: transform 0.25s ease;
  display: flex;
  flex-direction: column;
  box-shadow: 4rpx 0 20rpx rgba(0,0,0,0.12);
}
.drawer-open {
  transform: translateX(0);
}
.drawer-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 60rpx 32rpx 24rpx;
  border-bottom: 1rpx solid #f0f0f0;
}
.drawer-title {
  font-size: 32rpx;
  font-weight: bold;
  color: #333;
}
.drawer-new-btn {
  font-size: 26rpx;
  color: #4CAF50;
  padding: 8rpx 20rpx;
  border: 1rpx solid #4CAF50;
  border-radius: 24rpx;
}
.drawer-list {
  flex: 1;
  padding: 16rpx 0;
}
.drawer-item {
  display: flex;
  align-items: center;
  padding: 24rpx 32rpx;
  border-bottom: 1rpx solid #f5f5f5;
}
.drawer-item-active {
  background: #f1f8f1;
}
.drawer-item-title {
  flex: 1;
  font-size: 28rpx;
  color: #333;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}
.drawer-item-del {
  font-size: 28rpx;
  color: #bbb;
  padding: 4rpx 12rpx;
  margin-left: 12rpx;
}


.mode-btn {
  width: 80rpx;
  height: 72rpx;
  border-radius: 20rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 24rpx;
  font-weight: bold;
  flex-shrink: 0;
}
.mode-pro   { background: #e8f5e9; color: #2e7d32; }
.mode-flash { background: #fff8e1; color: #f57f17; }
.send-btn {
  width: 100rpx;
  height: 72rpx;
  border-radius: 20rpx;
  background: #4CAF50;
  color: #fff;
  font-size: 28rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
}
.send-btn-disabled {
  background: #bdbdbd;
}

/* 发送中加载点 */
.loading-dot {
  width: 16rpx;
  height: 16rpx;
  border-radius: 50%;
  background: #fff;
  animation: pulse 0.8s infinite;
}
@keyframes pulse {
  0%, 100% { opacity: 1; transform: scale(1); }
  50%       { opacity: 0.4; transform: scale(0.7); }
}

/* ── 键盘/语音切换按钮 ── */
.voice-toggle-btn {
  width: 60rpx;
  height: 72rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 36rpx;
  flex-shrink: 0;
}

/* ── 图片上传按钮 ── */
.image-upload-btn {
  width: 60rpx;
  height: 72rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 36rpx;
  flex-shrink: 0;
}

/* ── 图片预览 ── */
.image-preview {
  position: relative;
  width: 120rpx;
  height: 120rpx;
  margin: 0 12rpx;
  border-radius: 12rpx;
  overflow: hidden;
  border: 2rpx solid #4CAF50;
  flex-shrink: 0;
}
.image-preview image {
  width: 100%;
  height: 100%;
}
.image-preview-close {
  position: absolute;
  top: -8rpx;
  right: -8rpx;
  width: 40rpx;
  height: 40rpx;
  background: #f44336;
  color: #fff;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 32rpx;
  font-weight: bold;
  line-height: 1;
}

/* ── 按住说话按钮 ── */
.voice-btn {
  flex: 1;
  height: 72rpx;
  border-radius: 20rpx;
  background: #e8f5e9;
  color: #2e7d32;
  font-size: 28rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  /* 重置 button 默认样式 */
  border: none;
  padding: 0;
  margin: 0;
  line-height: 72rpx;
}
.voice-btn::after { border: none; }
.voice-btn-recording {
  background: #ffebee;
  color: #c62828;
}
