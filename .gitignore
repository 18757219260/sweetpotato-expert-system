# ==========================================
# 1. 运行时编译产物与缓存 (Python Cache)
# 针对截图中可见的 __pycache__ 目录
# ==========================================
**/__pycache__/
*.py[cod]
*$py.class

# ==========================================
# 2. 局部依赖与虚拟环境隔离 (Virtual Environments)
# 针对截图中可见的 .venv 目录
# ==========================================
.venv/
venv/
ENV/

# ==========================================
# 3. 凭证隔离与系统级安全 (Security & Credentials)
# ==========================================
.env
.env.*

# ==========================================
# 4. 数据库状态持久化文件 (Database State)
# 针对截图中 backend/data 下的物理文件
# ==========================================
# 忽略 SQLite 关系型数据库文件
backend/data/app.db
*.sqlite3
# 忽略 ChromaDB 向量数据库生成的二进制索引目录（极其重要，否则会引发严重的代码库体积膨胀）
backend/data/chroma_db/

# ==========================================
# 5. 动态多媒体流与 I/O 挂载目录 (Media & I/O)
# 针对截图中可见的 static/images 目录
# ==========================================
backend/static/images/
temp_audio_files/
*.wav
*.jpg
*.png

# ==========================================
# 6. 微信小程序特定的本地隐私配置 (Miniprogram)
# 针对 miniprogram 目录下的私有配置
# ==========================================
miniprogram/project.private.config.json

# ==========================================
# 7. IDE 配置文件与操作系统元数据 (IDE & OS Metadata)
# ==========================================
.vscode/
.idea/
.DS_Store